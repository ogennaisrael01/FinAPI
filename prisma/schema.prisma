// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Test {
  id String @id @unique @default(uuid())
}

model User {
  id String @id @unique @default(uuid())

  firstName String? 
  middleName String?
  lastName String?

  email String? @unique
  phone String @unique

  passwordHash String
  pinHash String?

  kycTier Int @default(0)

  phoneVerified Boolean @default(false)
  emailVerified Boolean @default(false)
  bvnVerified Boolean @default(false)
  ninVerified Boolean @default(false)
  isFrozen Boolean @default(false)

  flwCustomerId String?
  profilePhotoUrl Json? @default("{}")
  dateOfBirth String? 
  gender String?
  address Json? @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@index([flwCustomerId])
  @@index([kycTier])
  @@index([phoneVerified])
  @@index([createdAt])
  @@index([bvnVerified])
  @@index([ninVerified])
  @@index([isFrozen])

  // relations
  otpCodes OtpCodes[]
  outstandingTokens OutstandingToken[]
  keyDocument KycDocuments[]
  virtualAccount VirtualAccounts?
  wallet Wallet?
}

model OtpCodes {
  id String @id @unique @default(uuid())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  otpHash String 

  type String

  attempts Int @default(0) // 0 - 3
  createdAt DateTime @default(now())
  usedAt DateTime?
  isUsed Boolean @default(false)
  expiresAt DateTime

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([isUsed])
  @@index([attempts])
  @@index([usedAt])
  @@index([otpHash])
}

model KycDocuments {
  id String @id @default(uuid()) 

  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  bvnEncrypted String?
  ninEncrypted String?
  idType String?
  idDocURL String?

  bvnVerifiedAt DateTime?
  ninVerifiedAt DateTime?
  idVerifiedAt DateTime?

  rejectionCount Int @default(0)
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([id])
  @@index([createdAt])
}


model VirtualAccounts {
  id String @id @default(uuid())

  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  accountNumber String @unique
  accountName String
  bankName String?
  bankCode String
  monnifyRef String? @unique
 
  isActive Boolean @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([accountNumber, bankCode])
  @@index([monnifyRef])
  @@index([isActive])
  @@index([createdAt])
}


model Wallet {
  id String @id @default(uuid()) @unique

  userId  String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance Int @default(0)
  lockedBalance Int @default(0)

  currency String @default('NGN')
  isFrozen Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OutstandingToken {
  id  String @id @default(uuid())

  userId String
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime 

  jti String
  token String

  blacklistTokens BlacklistedToken[]

  @@index([jti])
  @@index([expiresAt])
  @@index([userId])

}

model BlacklistedToken {
  id String @id @default(uuid())

  tokenId String
  token OutstandingToken @relation(fields:[tokenId], references: [id], onDelete:Cascade)

  blacklistedAt DateTime @default(now())

  @@index([tokenId])
}
